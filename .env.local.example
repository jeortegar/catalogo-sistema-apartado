# ─────────────────────────────────────────────
#  BRANDING
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Mi Negocio"
NEXT_PUBLIC_SITE_URL=https://minegocio.com

# Número de WhatsApp en formato internacional sin espacios ni guiones (ej. 521XXXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=521XXXXXXXXXX

# ─────────────────────────────────────────────
#  PAYLOAD CMS  (Railway u otro hosting)
# ─────────────────────────────────────────────
PAYLOAD_CMS_URL=https://tu-payload.up.railway.app
PAYLOAD_API_KEY=your_payload_api_key_here

# ─────────────────────────────────────────────
#  CONEKTA  (Pasarela de pago)
# ─────────────────────────────────────────────
# Modo prueba: copia tu test key desde https://app.conekta.com → Developers → API Keys
CONEKTA_API_KEY=key_xxxxxxxxxxxxxxxxxxx
CONEKTA_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────────
#  URLS INTERNAS
# ─────────────────────────────────────────────
# Usada por Conekta para success_url / failure_url (generalmente igual a NEXT_PUBLIC_SITE_URL)
NEXT_PUBLIC_APP_URL=https://minegocio.com

# ─────────────────────────────────────────────
#  REVALIDACIÓN ISR
# ─────────────────────────────────────────────
# Genera un token aleatorio seguro: openssl rand -hex 32
REVALIDATE_SECRET=your_revalidate_secret_here

# ─────────────────────────────────────────────
#  DESARROLLO
# ─────────────────────────────────────────────
# Pon "true" para correr sin Payload CMS (usa datos mock en lib/payload/mocks.ts)
USE_MOCK_DATA=false
